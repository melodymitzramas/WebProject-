    background:rgba(255,255,255,0.95);
    padding:30px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(200,150,255,0.4);
}

h2{
    margin-top:25px;
    margin-bottom:15px;
    color:#a64dff;
}

ol,ul{
    padding-left:30px;
    margin-bottom:15px;
}

li{
    margin:6px 0;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-top:15px;
}

thead{
    background:#caa6ff;
    color:white;
}

th,td{
    padding:12px;
    text-align:left;
}

tbody tr{
    border-bottom:1px solid #f0d6ff;
    transition:0.3s;
}

tbody tr:nth-child(even){
    background-color:#fff0ff;
}

tbody tr:hover{
    background-color:#f3d9ff;
    transform:scale(1.01);
}

tfoot{
    background:#f8e6ff;
    font-weight:bold;
}

footer{
    text-align:center;
    padding:15px;
    background:#b57aff;
    color:white;
    font-size:14px;
}

